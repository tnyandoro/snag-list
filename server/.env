# Database
DATABASE_URL=postgresql://property_admin:secure_password_123@localhost:5432/property_platform
DB_HOST=localhost
DB_PORT=5432
DB_USER=property_admin
DB_PASSWORD=secure_password_123
DB_NAME=property_platform

# JWT Auth
JWT_SECRET=your_super_secure_jwt_secret_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# File Storage (AWS S3 or Cloudflare R2)
S3_BUCKET=property-platform-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# External Services
STRIPE_SECRET_KEY=sk_test_your_key
PAYSTACK_SECRET_KEY=sk_test_your_key
